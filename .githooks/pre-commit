#!/bin/bash
# 预提交检查：凭据拦截 + 仓库卫生
#
# 激活（每台机器一次）：
#   git config core.hooksPath .githooks
#
# 绕过：SKIP_ROLE_CHECK=1 git commit ...

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'
BLOCKED=false

[ -n "$SKIP_ROLE_CHECK" ] && exit 0

STAGED=$(git diff --cached --name-only)
STAGED_ND=$(git diff --cached --name-status | awk '$1 != "D" {print $2}')

# ════════════════════════════════════════════════════════════════
# 检查 1：禁止混合提交代码/文档 + 运行结果
# ════════════════════════════════════════════════════════════════
has_run_output=false
has_code_or_docs=false
for f in $STAGED; do
  case "$f" in
    Markdowns/*.md|runs/*.md|.progress.json) has_run_output=true ;;
    *.py|requirements.txt|.gitignore|.gitattributes|COLLABORATION.md|AGENTS.md|CLAUDE.md) has_code_or_docs=true ;;
    githooks/*|.githooks/*|docs/*|.claude/*|.wolf/OPENWOLF.md|.wolf/anatomy.md|.wolf/buglog.json|.wolf/cerebrum.md|.wolf/config.json|.wolf/hooks/*|.wolf/identity.md|.wolf/memory.md|.wolf/reframe-frameworks.md) has_code_or_docs=true ;;
  esac
done
if [ "$has_code_or_docs" = true ] && [ "$has_run_output" = true ]; then
  echo -e "${RED}❌ BLOCKED:${NC} 禁止混合提交代码/文档和运行结果"
  echo "    请把 .progress.json、Markdowns/*.md、runs/*.md 分开提交。"
  echo "    绕过: SKIP_ROLE_CHECK=1 git commit"
  BLOCKED=true
fi

# ════════════════════════════════════════════════════════════════
# 检查 2：禁止提交本机运行产物、遥测、缓存、密钥文件
# ════════════════════════════════════════════════════════════════
FORBIDDEN_FILES=false
for f in $STAGED_ND; do
  case "$f" in
    Videos/*|cache/*|.gitnexus/*|graphify-out/*|__pycache__/*|*.pyc|*.wav|*.log) FORBIDDEN_FILES=true ;;
    .wolf/hooks/_session.json|.wolf/token-ledger.json|.wolf/cron-state.json|.wolf/designqc-report.json|.wolf/suggestions.json) FORBIDDEN_FILES=true ;;
    .claude/settings.local.json|*.env|.env.*) FORBIDDEN_FILES=true ;;
  esac
done
if [ "$FORBIDDEN_FILES" = true ]; then
  echo -e "${RED}❌ BLOCKED:${NC} 禁止提交本机运行产物、遥测、缓存或密钥文件"
  echo "    Videos/ cache/ .gitnexus/ graphify-out/ .wolf 本机会话遥测 .env 等不应进入 Git。"
  echo "    绕过: SKIP_ROLE_CHECK=1 git commit"
  BLOCKED=true
fi

# ════════════════════════════════════════════════════════════════
# 检查 3：凭据文件名模式（shell case glob，非正则）
# ════════════════════════════════════════════════════════════════
for f in $STAGED; do
  case "$f" in
    *auth_state*.json|*cookie*.txt|cookies.txt|*.key|*secret*|*cred*|*api_key*|*token*.txt|zhihu_token*)
      echo -e "${RED}❌ BLOCKED:${NC} 暂存区包含凭据文件: $f"
      BLOCKED=true
      ;;
  esac
done

# ════════════════════════════════════════════════════════════════
# 检查 4：内容级 API Key 扫描（跳过 .githooks/ 自身）
# ════════════════════════════════════════════════════════════════
CONTENT_DIFF=$(git diff --cached -U0 -- ':(exclude).githooks/*' 2>/dev/null || true)

# 值模式 —— 直接匹配密钥值本体
VALUE_PATTERNS=(
  'AIza[0-9A-Za-z_-]{20,}'        # Google API Key（Gemini）
  'sk-[a-zA-Z0-9]{20,}'           # OpenAI / DashScope compatible
  'sk-ant-[a-zA-Z0-9]{20,}'       # Anthropic / Claude API
  'ghp_[a-zA-Z0-9]{36}'           # GitHub personal access token
  'gho_[a-zA-Z0-9]{36}'           # GitHub OAuth
  'ghu_[a-zA-Z0-9]{36}'           # GitHub user token
)

for pat in "${VALUE_PATTERNS[@]}"; do
  MATCH=$(echo "$CONTENT_DIFF" | grep -E "^\+.*${pat}" || true)
  if [ -n "$MATCH" ]; then
    echo -e "${RED}❌ BLOCKED:${NC} 新增代码包含疑似 API Key / Token 值 (${pat})"
    echo "$MATCH" | head -3 | sed 's/^/    /'
    echo -e "${YELLOW}    使用环境变量（os.environ.get）代替硬编码${NC}"
    BLOCKED=true
  fi
done

# 变量名模式 —— 防止误把 KEY= 写死在源码中
VAR_PATTERNS=(
  'GEMINI_API_KEY'
  'DASHSCOPE_API_KEY'
  'DEEPSEEK_API_KEY'
  'OPENAI_API_KEY'
  'ANTHROPIC_API_KEY'
  'QWEN_API_KEY'
)

for name in "${VAR_PATTERNS[@]}"; do
  MATCH=$(echo "$CONTENT_DIFF" | grep -E "^\+.*[\"'\"]${name}[\"'\"]" | grep -vE 'os\.environ|process\.env|#|//|\brole\b|\bmodel\b' || true)
  if [ -n "$MATCH" ]; then
    echo -e "${YELLOW}⚠ WARNING:${NC} 新增行包含 API Key 变量名引用 '${name}'"
    echo "$MATCH" | head -3 | sed 's/^/    /'
    # WARNING only — 可能是 legitimate config key mapping
  fi
done

# ════════════════════════════════════════════════════════════════
# 检查 5：大文件警告
# ════════════════════════════════════════════════════════════════
for f in $STAGED; do
  count=$(git show :"$f" 2>/dev/null | wc -l | tr -d ' ')
  if [ -n "$count" ] && [ "$count" -gt 2000 ] 2>/dev/null; then
    echo -e "${YELLOW}⚠ WARNING:${NC} 暂存区包含大文件 $f (${count} 行)"
  fi
done

if [ "$BLOCKED" = true ]; then
  echo ""
  echo -e "${RED}提交被拦截。修正后重试。绕过: SKIP_ROLE_CHECK=1 git commit${NC}"
  exit 1
fi

exit 0
