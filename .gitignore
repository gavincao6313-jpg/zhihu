# 视频文件（体积过大）
Videos/

# 运行日志
*.log

# 本地预处理缓存
cache/

# 进度 & 配额（.progress.json 用 git 同步）
.progress.tmp.json
.progress.json.tmp

# macOS
.DS_Store

# Python
__pycache__/
*.pyc
.venv*/

# Local Claude/Codex machine permission state
.claude/settings.local.json

# Frontend dependencies and build output
frontend/node_modules/
frontend/dist/

# Playwright browser binaries (downloaded locally)
.playwright-browsers/

# Playwright persistent profile (xiaoe auth)
.playwright-xiaoe-profile/

# Local probe media
runs/*.wav
runs/web-run-registry.json

# Checkpoint files — deleted on clean exit; only committed accidentally
runs/*.checkpoint.json
Videos/.stream/requests/
Videos/.stream/storage_state*.json

# Zhihu auth secrets (all platforms)
zhihu_auth_state.json
zhihu_auth_state_xiaoe.json
zhihu_auth_state-*.json
zhihu_cookie*.txt
zhihucookies*.txt
cookies.txt
.last_stream_url.txt
.monitor_state.json
