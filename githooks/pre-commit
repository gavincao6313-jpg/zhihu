#!/bin/sh
#
# zhihuTTS 共享状态检查 hook
# 按文件用途检查，不按 Windows/Mac 机器身份检查。
#
# 绕过：SKIP_ROLE_CHECK=1 git commit ...

set -e

[ -n "$SKIP_ROLE_CHECK" ] && exit 0

# ── 检查本次 commit 涉及的文件 ─────────────────────────
staged=$(git diff --cached --name-only)
staged_non_deleted=$(git diff --cached --name-status | awk '$1 != "D" {print $2}')

has_run_output=$(echo "$staged" | grep -Ec '^Markdowns/.*\.md$|^runs/.*\.md$|^\.progress\.json$' || true)
has_code_or_docs=$(echo "$staged" | grep -Ec '\.py$|(^|/)(requirements\.txt|\.gitignore|\.gitattributes|COLLABORATION\.md|AGENTS\.md|CLAUDE\.md)$|^githooks/|^docs/|^\.claude/|^\.wolf/(OPENWOLF\.md|anatomy\.md|buglog\.json|cerebrum\.md|config\.json|hooks/|identity\.md|memory\.md|reframe-frameworks\.md)' || true)
has_forbidden_local=$(echo "$staged_non_deleted" | grep -Ec '^Videos/|^cache/|^\.gitnexus/|^graphify-out/|^__pycache__/|\.pyc$|\.wav$|\.log$|^\.wolf/hooks/_session\.json$|^\.wolf/token-ledger\.json$|^\.wolf/cron-state\.json$|^\.wolf/designqc-report\.json$|^\.wolf/suggestions\.json$|^\.claude/settings\.local\.json$|(^|/)\.env($|\.)' || true)

# ── 所有人：禁止提交本机运行产物、遥测、缓存和密钥文件 ─────
if [ "$has_forbidden_local" -gt 0 ]; then
    echo ""
    echo "  ❌ 禁止提交本机运行产物、遥测、缓存或密钥文件"
    echo "  ─────────────────────────────────────"
    echo "  Videos/**、cache/**、*.log、.gitnexus/**、graphify-out/**、"
    echo "  .wolf 本机会话遥测、.env 等不应进入 Git。"
    echo "  如需例外: SKIP_ROLE_CHECK=1 git commit ..."
    exit 1
fi

# ── 所有人：避免把代码变更和运行结果混在一个提交里 ───────
if [ "$has_code_or_docs" -gt 0 ] && [ "$has_run_output" -gt 0 ]; then
    echo ""
    echo "  ❌ 避免混合提交代码/协作文档和运行结果"
    echo "  ─────────────────────────────────────"
    echo "  请把代码/文档/tooling 改动，与 .progress.json、Markdowns/*.md、runs/*.md 分开提交。"
    echo "  如需例外: SKIP_ROLE_CHECK=1 git commit ..."
    exit 1
fi

exit 0
